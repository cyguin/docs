{
  "name": "@cyguin/docs",
  "version": "0.1.0",
  "description": "Drop-in docs widget and admin API for self-hosted Next.js apps",
  "license": "MIT",
  "keywords": [
    "cyguin",
    "docs",
    "knowledge-base",
    "nextjs",
    "self-hosted"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cyguin/docs"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "default": "./dist/next.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "dompurify": "^3.3.0",
    "marked": "^12.0.0",
    "nanoid": "^5.0.0"
  },
  "scripts": {
    "build": "rm -rf dist && tsup && cp src/styles.css dist/styles.css",
    "dev": "tsup --watch",
    "test": "vitest run",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run build && npm test && npm run pack:check"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "next": "^15.5.15",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.1"
  }
}
